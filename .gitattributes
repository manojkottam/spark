# Auto detect text files and perform LF normalization
* text=auto

# Source code - always use LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.json5 text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.html text eol=lf
*.htm text eol=lf
*.xml text eol=lf
*.svg text eol=lf
*.txt text eol=lf
*.graphql text eol=lf
*.gql text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows-specific files (keep CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files (do not modify)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Lockfiles (keep as-is)
package-lock.json text eol=lf
yarn.lock text eol=lf
pnpm-lock.yaml text eol=lf
*.lock text eol=lf

# Expo / React Native specific
*.podspec text eol=lf
Podfile text eol=lf
Podfile.lock text eol=lf
*.pbxproj text eol=lf
*.xcconfig text eol=lf
*.plist text eol=lf
*.entitlements text eol=lf
*.storyboard text eol=lf
*.xib text eol=lf
